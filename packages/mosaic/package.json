{
	"name": "@arbor/mosaic",
	"version": "0.1.0",
	"description": "Universal document understanding: any document → typed AST → Markdown/LaTeX. Local-first, in-process, Node-portable. Text, handwriting, formula OCR, layout, tables.",
	"type": "module",
	"license": "MIT",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"mosaic": "./dist/cli.js"
	},
	"files": ["dist"],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "bun test",
		"cli": "bun run src/cli.ts"
	},
	"dependencies": {
		"@gutenye/ocr-node": "^1.4.8",
		"@langchain/community": "^1.1.29",
		"d3-dsv": "2",
		"mammoth": "^1.12.0",
		"mupdf": "^1.27.0",
		"officeparser": "^7.2.2",
		"onnxruntime-node": "^1.27.0",
		"sharp": "^0.33.5"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"tsup": "^8.3.0",
		"typescript": "^5.6.0"
	},
	"engines": {
		"node": ">=18"
	}
}
