{
	"name": "arbor",
	"private": true,
	"description": "Arbor — spatial research canvas. frontend/ = UI + thin Tauri shell, backend/ = all processing behind a local HTTP/SSE API.",
	"workspaces": ["packages/*"],
	"scripts": {
		"dev": "cd frontend && npx tauri dev",
		"dev:web": "cd frontend && npm run dev",
		"dev:backend": "cd backend && bun run dev",
		"build": "cd frontend && npx tauri build",
		"build:windows": "powershell -ExecutionPolicy Bypass -File scripts/build-windows.ps1",
		"build:macos": "bash scripts/build-macos.sh",
		"test": "cd backend && bun test && cd ../frontend && npm test",
		"test:backend": "cd backend && bun test",
		"test:frontend": "cd frontend && npm test"
	},
	"dependencies": {
		"fallow": "^2.102.0"
	}
}
